{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "baseUrl": "../..",
    "paths": {
      "@maayanhot/contracts": ["packages/contracts/src/index.ts"],
      "@maayanhot/design-tokens": ["packages/design-tokens/src/index.ts"],
      "@maayanhot/domain": ["packages/domain/src/index.ts"],
      "@maayanhot/map-core": ["packages/map-core/src/index.ts"],
      "@maayanhot/navigation-core": ["packages/navigation-core/src/index.ts"],
      "@maayanhot/shared-utils": ["packages/shared-utils/src/index.ts"],
      "@maayanhot/ui": ["packages/ui/src/index.ts"],
      "@maayanhot/upload-core": ["packages/upload-core/src/index.ts"],
      "@maayanhot/use-cases": ["packages/use-cases/src/index.ts"]
    }
  },
  "include": ["app/**/*", "**/*.d.ts", "**/*.ts", "**/*.tsx"]
}
